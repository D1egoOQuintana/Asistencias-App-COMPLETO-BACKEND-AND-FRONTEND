# Variables de entorno para Sistema de Asistencias
# Copiar a .env para desarrollo local

# Firebase Configuration
FIREBASE_PROJECT_ID=asistencias-backend
FIREBASE_DATABASE_URL=https://asistencias-backend-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=asistencias-backend.appspot.com

# Authentication
PASSWORD_RESET_URL=http://localhost:3000/reset-password
JWT_EXPIRATION=24h
SESSION_TIMEOUT=86400

# Development
NODE_ENV=development
LOG_LEVEL=debug
ENABLE_STRUCTURED_LOGGING=true

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_INSTANCES=10
REQUEST_TIMEOUT=30000
MAX_UPLOAD_SIZE=10485760

# Functions Emulator
FUNCTIONS_EMULATOR=true

# WhatsApp Cloud API (Production/Blaze)
# Copia estos a .env.<tu_proyecto> o .env.production y rellena valores reales
WABA_API_VERSION=v20.0
WABA_PHONE_NUMBER_ID=
WABA_TEMPLATE_NAME=asistencia_alumno
WABA_LANGUAGE_CODE=es
WHATSAPP_TOKEN=
