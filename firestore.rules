rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() { return request.auth != null; }
    // Preferir custom claims cuando existan; fallback al documento en /users/{uid}
    function hasRole(role) {
      return (
        isAuthed() && (
          request.auth.token.role == role || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role
          )
        )
      );
    }
    function isAdmin() { return hasRole('admin'); }
    function isDocente() { return hasRole('docente') || hasRole('teacher'); }
    function isAdminEmail() {
      // Lista de emails de administradores permitidos
      return request.auth.token.email in ['admin@asistencias.com', 'luisangelfabian10@gmail.com'];
    }
    function isDocenteOrAdmin() {
      return isDocente() || isAdmin() || isAdminEmail();
    }

    // Acceso a un salón para docentes: dueño del salón o asignado explícitamente.
    // teacherUid sigue siendo el campo principal; teacherUids (lista) habilita
    // polidocente sin reemplazar al principal. Se verifica con guard de
    // existencia para no romper docs legacy que aún no tengan la lista.
    function hasClassroomAccess(classroomId) {
      return isAuthed() && (
        (
          exists(/databases/$(database)/documents/classrooms/$(classroomId)) &&
          (
            get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherUid == request.auth.uid ||
            get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid ||
            get(/databases/$(database)/documents/classrooms/$(classroomId)).data.ownerUid == request.auth.uid ||
            (
              'teacherUids' in get(/databases/$(database)/documents/classrooms/$(classroomId)).data &&
              request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherUids
            )
          )
        ) || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            'assignedClassrooms' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
            classroomId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedClassrooms
          )
        )
      );
    }

    match /users/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAdmin() || isAdminEmail());
      allow create: if isAuthed() && (isAdmin() || isAdminEmail() || request.auth.uid == uid);  
      allow update: if isAuthed() && (request.auth.uid == uid || isAdmin() || isAdminEmail());
      allow delete: if isAdmin() || isAdminEmail();
    }

    match /courses/{courseId} {
      allow create: if isDocente() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isAuthed() && (isAdmin() || resource.data.createdBy == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
      allow update, delete: if isDocente() && resource.data.createdBy == request.auth.uid;
    }

    match /students/{studentId} {
      allow create, read, update: if isAuthed();
      allow delete: if (isAdmin() || isAdminEmail());
    }

    match /classrooms/{classroomId} {
      // Create/read: cualquier usuario autenticado.
      allow create, read: if isAuthed();

      // Update: cualquier autenticado, salvo cambios en `schedule`
      // (horario), que quedan restringidos a admin. El QR y la asistencia
      // no modifican `schedule`, así que esto no afecta su flujo.
      allow update: if isAuthed() && (
        (isAdmin() || isAdminEmail()) ||
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['schedule'])
      );

      // Eliminar: Solo admin
      allow delete: if (isAdmin() || isAdminEmail());
    }

    match /classrooms/{classroomId}/attendance/{attendanceId} {
      allow read: if isAuthed() &&
        ((isAdmin() || isAdminEmail()) || hasClassroomAccess(classroomId));

      allow create: if isAuthed() &&
        ((isAdmin() || isAdminEmail()) || hasClassroomAccess(classroomId)) &&
        (request.resource.data.status in ['present', 'late', 'absent', 'presente', 'tarde', 'ausente']);

      allow update: if isAuthed() &&
        ((isAdmin() || isAdminEmail()) || hasClassroomAccess(classroomId)) &&
        (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) ||
          (request.resource.data.status in ['present', 'late', 'absent', 'presente', 'tarde', 'ausente'])
        );

      allow delete: if (isAdmin() || isAdminEmail());
    }

    match /classrooms/{classroomId}/attendance_events/{eventId} {
      allow read: if isAuthed() &&
        ((isAdmin() || isAdminEmail()) || hasClassroomAccess(classroomId));

      allow create: if isAuthed() &&
        ((isAdmin() || isAdminEmail()) || hasClassroomAccess(classroomId)) &&
        (
          request.resource.data.eventType in ['entry', 'exit'] &&
          request.resource.data.source in ['qr', 'manual', 'system']
        );

      allow update: if false;
      allow delete: if (isAdmin() || isAdminEmail());
    }

    match /academic_periods/{periodId} {
      allow read: if isAuthed();
      allow create, update, delete: if (isAdmin() || isAdminEmail());
    }

    match /attendance/{attendanceId} {
      // Crear/leer/actualizar para usuarios autenticados con acceso al aula.
      allow create: if isAuthed() &&
        (
          (isAdmin() || isAdminEmail()) ||
          (
            request.resource.data.classroomId is string &&
            hasClassroomAccess(request.resource.data.classroomId)
          )
        ) &&
        (
          !('status' in request.resource.data) ||
          (request.resource.data.status in ['present', 'late', 'absent', 'presente', 'tarde', 'ausente'])
        );

      // Permitir lectura autenticada para soportar transacciones QR cuando
      // el documento aún no existe (get inicial en registerQrScanForDay).
      allow read: if isAuthed();

      allow update: if isAuthed() &&
        (
          (isAdmin() || isAdminEmail()) ||
          (
            (resource.data.classroomId is string && hasClassroomAccess(resource.data.classroomId)) ||
            (request.resource.data.classroomId is string && hasClassroomAccess(request.resource.data.classroomId))
          )
        ) &&
        // Validar que el status sea válido si se está cambiando
        (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) ||
          (request.resource.data.status in ['present', 'late', 'absent', 'presente', 'tarde', 'ausente'])
        ) &&
        // Permitir campos adicionales necesarios
        (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['editedBy']) ||
          (request.resource.data.editedBy is string)
        );

      // Eliminar: solo admin
      allow delete: if (isAdmin() || isAdminEmail());
    }

    // Reglas para las sesiones de asistencia
    match /attendance_sessions/{sessionId} {
      allow create, read, update: if isAuthed();
      allow delete: if (isAdmin() || isAdminEmail());
    }

    // Reglas para los registros de asistencia legados (si se usan)
    match /attendances/{attendanceRecordId} {
      allow create, read: if isAuthed();
      // Restringir updates a admin para evitar inconsistencias con el modelo actual
      allow update, delete: if (isAdmin() || isAdminEmail());
    }

    // Reglas para la colección de whatsapp logs
    match /whatslog/{id} {
      allow read: if isAdmin() || isAdminEmail();
      allow write: if false; // solo Functions
    }
  }
}
